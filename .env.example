# Copy to .env and fill in. Never commit the real file (.gitignore already
# excludes .env / *.env). Load it locally with `uv run --env-file .env ...`.
#
# Prefer a guided walkthrough? tools/setup_wizard.py generates this file for you:
#   uv run --extra setup-wizard streamlit run tools/setup_wizard.py

# --- Cloud Run service (server/app.py, server/gh_app_auth.py) ---
# GitHub App ID — JWT issuer for minting installation tokens.
APP_ID=
# GitHub App private key (PEM), single line with \n for newlines.
APP_KEY=
# Verifies the webhook's X-Hub-Signature-256 header.
WEBHOOK_SECRET=

# --- Inference providers (scripts/llm_client.py) ---
# Primary: Groq (free tier, no card). console.groq.com -> API Keys.
GROQ_API_KEY=
# Fallback: GitHub Models. Fine-grained PAT with the `models: read` scope.
MODELS_PAT=

# --- Optional: shared rate-limit caps/dedup across instances (scripts/limits.py) ---
# Unset -> in-memory (per-instance), fine for local dev / single instance.
# LIMITS_BACKEND=firestore

# --- Legacy GitHub Actions workflow vars ---
# GitHub Actions injects these automatically (GITHUB_TOKEN -> MODELS_TOKEN,
# GITHUB_REPOSITORY, PR_NUMBER, ...). Only set them here to run a scripts/*.py
# entry point directly on your machine outside of a workflow.
GH_TOKEN=
GITHUB_REPOSITORY=owner/repo
PR_NUMBER=
PR_DIFF_FILE=
PR_AUTHOR=
MODELS_TOKEN=
